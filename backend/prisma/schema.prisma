generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id // matches Supabase auth user id
  name      String
  phone     String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  memberships  GroupMember[]
  paidExpenses Expense[]       @relation("PaidBy")
  createdExpenses Expense[]    @relation("CreatedBy")
  sentSettlements     Settlement[] @relation("From")
  receivedSettlements Settlement[] @relation("To")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  emoji       String   @default("🏠")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  inviteToken InviteToken?
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id        String   @id @default(uuid())
  groupId   String
  title     String
  amount    Float
  paidById  String
  splitType String   @default("equal") // equal | custom
  note      String?
  createdById String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy    Profile        @relation("PaidBy", fields: [paidById], references: [id])
  createdBy Profile        @relation("CreatedBy", fields: [createdById], references: [id])
  splits    ExpenseSplit[]
}

model ExpenseSplit {
  id        String  @id @default(uuid())
  expenseId String
  userId    String
  amount    Float
  settled   Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String
  fromId    String
  toId      String
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  group Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  from  Profile @relation("From", fields: [fromId], references: [id])
  to    Profile @relation("To", fields: [toId], references: [id])
}

model InviteToken {
  token     String   @id @default(uuid())
  groupId   String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
